# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class

# Jupyter cache/checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Virtual environments and local environment files
venv/
env/
.venv/
ENV/
.env
.env.*
!.env.example

# Data files, but keep the folder README
data/*
!data/README.md

datasets/
raw_data/
processed_data/

# Checkpoints/model weights, but keep the folder README
checkpoints/*
!checkpoints/README.md

models/
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.onnx
*.pkl
*.joblib

# Training logs and experiment tracking folders
runs/
wandb/
tensorboard/
logs/
mlruns/

# Keep results files such as CSVs, tables, and plots
# Do not ignore results/ because this repo may include:
# - best configuration CSV files
# - model comparison tables
# - confusion matrix plots
# - saved final result plots

# Large compressed files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Large generated media
*.mp4
*.avi
*.mov
*.mkv
*.webm

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo
